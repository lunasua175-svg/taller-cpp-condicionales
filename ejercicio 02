#include <iostream>

int main() {
    double a, b, c;

    std::cout << "Ingrese los tres lados del triangulo: ";
    std::cin >> a >> b >> c;

    if (a+b>c && a+c>b && b+c>a) {
        if (a==b && b==c)
            std::cout << "Equilatero";
        else if (a==b || b==c || a==c)
            std::cout << "Isosceles";
        else
            std::cout << "Escaleno";
    } else {
        std::cout << "No es un triangulo";
    }

    return 0;
}
