#include <iostream>

int main() {
    const int LEER = 0b001;      // 1
    const int ESCRIBIR = 0b010;  // 2
    const int EJECUTAR = 0b100;  // 4

    int valor;
    std::cout << "Ingrese valor de permisos (0-7): ";
    std::cin >> valor;

    std::cout << "Permisos: \n";
    if (valor & LEER) std::cout << "- LEER\n";
    if (valor & ESCRIBIR) std::cout << "- ESCRIBIR\n";
    if (valor & EJECUTAR) std::cout << "- EJECUTAR\n";

    return 0;
}
