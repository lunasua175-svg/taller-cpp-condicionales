#include <iostream>
#include <string>

int main() {
    int nota;
    std::cout << "Ingresar la nota (0-100): ";
    std::cin >> nota;

    char letra;
    if (nota >= 90) letra = 'A';
    else if (nota >= 80) letra = 'B';
    else if (nota >= 70) letra = 'C';
    else if (nota >= 60) letra = 'D';
    else letra = 'F';

    std::string estado;
    if (nota >= 60)
        estado = "Aprobado";
    else
        estado = "Reprobado";

    std::cout << "Letra: " << letra << " | Estado: " << estado << "\n";

    return 0;
}
